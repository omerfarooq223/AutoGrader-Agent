# ── AutoGrader Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.

GROQ_API_KEY=your-api-key-here
MODEL=llama-3.3-70b-versatile

# Max parallel grading API calls (keep ≤ 5 to respect rate limits)
MAX_CONCURRENT_GRADES=4

# Retry attempts for failed API calls
MAX_RETRIES=3

# Grading scale
TOTAL_MARKS=100
PASS_THRESHOLD=50

# Plagiarism cosine-similarity threshold (0.0 – 1.0)
SIMILARITY_THRESHOLD=0.65

# Output filenames
OUTPUT_FILENAME=grading_report.xlsx
CACHE_FILENAME=.grading_cache.json
